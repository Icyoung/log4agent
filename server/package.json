{
  "name": "log4agent-server",
  "version": "0.1.1",
  "description": "Local mobile log collector for coding agents.",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "log4agent-server": "bin/log4agent-server.js"
  },
  "scripts": {
    "start": "node bin/log4agent-server.js start",
    "start:fg": "node bin/log4agent-server.js start",
    "start:bg": "node bin/log4agent-server.js start --background",
    "stop": "node bin/log4agent-server.js stop",
    "status": "node bin/log4agent-server.js status",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mobile",
    "logging",
    "android",
    "ios",
    "flutter",
    "kmp",
    "coding-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Icyoung/log4agent.git",
    "directory": "server"
  },
  "bugs": {
    "url": "https://github.com/Icyoung/log4agent/issues"
  },
  "homepage": "https://github.com/Icyoung/log4agent#readme",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
